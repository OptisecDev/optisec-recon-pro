# ── OPTISEC Recon Pro — Environment Variables ──────────────
# Copy to .env and fill in values. deploy.sh auto-generates .env if missing.

# ─── Security (REQUIRED — change defaults!) ───────────────
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
OPTISEC_LICENSE_SECRET=change-me-license-secret

# ─── Database ─────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
# docker-compose.yml sets DATABASE_URL automatically via POSTGRES_PASSWORD.
# For manual / local dev, set it explicitly:
# DATABASE_URL=postgresql+asyncpg://optisec:PASS@localhost:5432/optisec
# DATABASE_URL=sqlite+aiosqlite:///./data/optisec.db

# ─── First Admin Account (first-run only) ─────────────────
FIRST_ADMIN_USER=admin
FIRST_ADMIN_EMAIL=admin@yourdomain.com
FIRST_ADMIN_PASSWORD=Optisec123!

# ─── Auth ─────────────────────────────────────────────────
JWT_EXPIRE_HOURS=24

# ─── AI Features ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Bug Bounty Platforms ─────────────────────────────────
HACKERONE_USERNAME=
HACKERONE_API_TOKEN=
BUGCROWD_API_TOKEN=
INTIGRITI_API_TOKEN=

# ─── CVE Submission ───────────────────────────────────────
NVD_API_KEY=
CVE_CNA_ORG=
CVE_CNA_USERNAME=
CVE_CNA_API_KEY=

# ─── Threat Intelligence ──────────────────────────────────
OTX_API_KEY=your_alienvault_otx_api_key_here

# ─── Network Intelligence (optional) ──────────────────────
# Shodan: leave blank to fall back to the free Shodan InternetDB
# (https://internetdb.shodan.io) — no key required, IP-only data.
SHODAN_API_KEY=
# Censys: both must be set or Censys lookups are skipped.
CENSYS_API_ID=
CENSYS_API_SECRET=

# ─── Dark Web & Breach Intelligence (optional) ────────────
# HIBP: paid key required — there is no free tier for the breach/paste APIs.
HIBP_API_KEY=
# IntelligenceX, BreachDirectory (RapidAPI) and Leak-Lookup are each
# optional and degrade to available=false if their key is unset.
INTELX_API_KEY=
RAPIDAPI_KEY=
LEAKLOOKUP_API_KEY=
# GitHub Code Search works unauthenticated (10 req/min); a token raises
# that ceiling. Threat-actor lookups reuse OTX_API_KEY above.
GITHUB_TOKEN=
