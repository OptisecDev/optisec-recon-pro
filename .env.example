# ── OPTISEC Recon Pro — Environment Variables ──────────────
# Copy to .env and fill in values. deploy.sh auto-generates .env if missing.

# ─── Security (REQUIRED — change defaults!) ───────────────
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
OPTISEC_LICENSE_SECRET=change-me-license-secret

# ─── Database ─────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
# docker-compose.yml sets DATABASE_URL automatically via POSTGRES_PASSWORD.
# For manual / local dev, set it explicitly:
# DATABASE_URL=postgresql+asyncpg://optisec:PASS@localhost:5432/optisec
# DATABASE_URL=sqlite+aiosqlite:///./data/optisec.db

# ─── First Admin Account (first-run only) ─────────────────
FIRST_ADMIN_USER=admin
FIRST_ADMIN_EMAIL=admin@yourdomain.com
FIRST_ADMIN_PASSWORD=Optisec123!

# ─── Auth ─────────────────────────────────────────────────
JWT_EXPIRE_HOURS=24

# ─── AI Features ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Bug Bounty Platforms ─────────────────────────────────
HACKERONE_USERNAME=
HACKERONE_API_TOKEN=
BUGCROWD_API_TOKEN=
INTIGRITI_API_TOKEN=

# ─── CVE Submission ───────────────────────────────────────
NVD_API_KEY=
CVE_CNA_ORG=
CVE_CNA_USERNAME=
CVE_CNA_API_KEY=

# ─── Threat Intelligence ──────────────────────────────────
OTX_API_KEY=your_alienvault_otx_api_key_here

# ─── Network Intelligence (optional) ──────────────────────
# Shodan: leave blank to fall back to the free Shodan InternetDB
# (https://internetdb.shodan.io) — no key required, IP-only data.
SHODAN_API_KEY=
# Censys: both must be set or Censys lookups are skipped.
CENSYS_API_ID=
CENSYS_API_SECRET=

# ─── Dark Web & Breach Intelligence (optional) ────────────
# HIBP: paid key required — there is no free tier for the breach/paste APIs.
HIBP_API_KEY=
# IntelligenceX, BreachDirectory (RapidAPI) and Leak-Lookup are each
# optional and degrade to available=false if their key is unset.
INTELX_API_KEY=
RAPIDAPI_KEY=
LEAKLOOKUP_API_KEY=
# GitHub Code Search works unauthenticated (10 req/min); a token raises
# that ceiling. Threat-actor lookups reuse OTX_API_KEY above.
GITHUB_TOKEN=

# ─── Free-Tier OSINT Sources (optional) ────────────────────
# Every key below is optional — each source degrades to available=false
# with a clear message when unset. All have generous free tiers; none
# require a paid plan to use as configured here.
# VirusTotal: 500 requests/day, 4/min. Sign up: https://www.virustotal.com/gui/join-us
VT_API_KEY=
# AbuseIPDB: 1,000 checks/day. Sign up: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=
# FullHunt: limited free monthly subdomain lookups. Sign up: https://fullhunt.io/auth/register/
FULLHUNT_API_KEY=
# LeakCheck: public endpoint works keyless; key unlocks the fuller v2 API.
# Sign up: https://leakcheck.io/register
LEAKCHECK_API_KEY=
# SecurityTrails: 50 requests/month free. Sign up: https://securitytrails.com/app/signup
SECURITYTRAILS_API_KEY=
# Google Safe Browsing: 10,000 requests/day free.
# Sign up: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
GOOGLE_API_KEY=
# URLScan.io needs no key at all — fully free, keyless public search API.
